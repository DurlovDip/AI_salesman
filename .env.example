# ============================================================
#  AI Salesman — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env

# ── Meta Platform ────────────────────────────────────────────
# Get these from https://developers.facebook.com/apps/
META_APP_SECRET=your_app_secret_here
META_VERIFY_TOKEN=fashionarc_verify_2024

# Facebook Messenger (from Page Settings → Advanced Messaging)
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
META_PAGE_ID=your_page_id_here

# WhatsApp Business API (from Meta Business Suite → WhatsApp)
META_WHATSAPP_TOKEN=your_whatsapp_token_here
META_WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id_here

# ── External APIs ────────────────────────────────────────────
# Your Fashion ARC backend
FASHION_ARC_API_URL=https://fashionarc-backend.vercel.app

# Your Multi-AI Stable API (for tool calling with failover)
MULTI_AI_API_URL=http://localhost:8000

# Direct AI keys (used if Multi-AI API is not available)
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# ── Supabase Database ─────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# ── Store Branding ───────────────────────────────────────────
STORE_NAME=Fashion ARC
STORE_URL=https://fa.bingo
STORE_CURRENCY=BDT

# ── Conversation Settings ────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
MAX_HISTORY_MESSAGES=20

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
DEBUG=true
